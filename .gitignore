# Secrets and environment files (all workspace levels)
.env
.env.*
!.env.example
**/.env
**/.env.*
!**/.env.example

# Local Codex configuration, skills and agent state
.codex/
**/.codex/

# Dependencies and package-manager caches
node_modules/
**/node_modules/
.pnp
.pnp.*
.yarn/
.npm/

# Framework and compiler output
.next/
**/.next/
dist/
**/dist/
build/
**/build/
out/
coverage/
**/coverage/
.turbo/
.cache/
*.tsbuildinfo
next-env.d.ts

# Local runtime data and uploads
*.sqlite
*.sqlite3
*.db
uploads/
storage/

# Private ebook storage: keep folder documentation, never commit book files
!backend/storage/
!backend/storage/private/
!backend/storage/private/ebooks/
backend/storage/private/ebooks/*
!backend/storage/private/ebooks/README.md
!backend/storage/private/ebooks/.gitkeep
!backend/storage/private/ebooks/dac-nhan-tam.pdf
!backend/src/modules/storage/
!backend/src/modules/storage/**

# Private keys and certificates
*.pem
*.key
*.p12
*.pfx
secrets/

# Logs and debug output
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Editors and operating systems
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db
Desktop.ini

# Local migration artifacts
*-migration-backup/
