NODE_ENV=development
PORT=4000
TZ=Asia/Ho_Chi_Minh
CLIENT_URL=http://localhost:3000
BACKEND_URL=http://localhost:4000
# Production frontend: https://book-frontend-mocha-rho.vercel.app
# Production backend: https://kkh34qrhp0.execute-api.ap-southeast-1.amazonaws.com
DATABASE_URL=mongodb://localhost:27017/capstonebook
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d
PAYOS_CLIENT_ID=
PAYOS_API_KEY=
PAYOS_CHECKSUM_KEY=
PAYOS_ENABLED=true
PAYOS_RETURN_URL=http://localhost:3000/payment/payos/success
PAYOS_CANCEL_URL=http://localhost:3000/payment/payos/cancel
PAYOS_WEBHOOK_URL=
# Production: https://kkh34qrhp0.execute-api.ap-southeast-1.amazonaws.com/api/v1/payments/payos/webhook
PAYOS_PAYMENT_EXPIRES_MINUTES=15

# Private PDF storage on Cloudflare R2 (backend only)
BOOK_STORAGE_DRIVER=r2
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_ENDPOINT=
R2_REGION=auto
ALLOW_EBOOK_DOWNLOAD=false
MAX_EBOOK_SIZE_MB=50

# Google login
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:4000/api/v1/auth/google/callback

# Gmail OAuth for password reset OTP
EMAIL_ENABLED=false
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=
GMAIL_SENDER_EMAIL=
MAIL_FROM_NAME=CapstoneBook

# AI assistant (backend only)
AI_ENABLED=false
AI_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
AI_MAX_OUTPUT_TOKENS=500
AI_REQUEST_TIMEOUT_MS=20000

# Frontend: put this one in frontend/.env.local
NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1
# Production: https://kkh34qrhp0.execute-api.ap-southeast-1.amazonaws.com/api/v1
